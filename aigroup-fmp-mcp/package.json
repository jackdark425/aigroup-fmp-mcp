{
  "name": "aigroup-fmp-mcp",
  "version": "1.0.0",
  "mcpName": "com.aigroup/aigroup-fmp-mcp",
  "description": "AIGroup Financial Modeling Prep MCP Server - Model Context Protocol server for financial data, market insights, and analysis",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "aigroup-fmp-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "prePublishOnly": "npm run build",
    "dev": "tsx watch src/index.ts",
    "setup": "npm install",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "author": "aigroup",
  "license": "Apache-2.0",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.0",
    "axios": "^1.13.2",
    "commander": "^14.0.0",
    "fastify": "^5.7.2",
    "minimist": "^1.2.8",
    "toolception": "^0.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/minimist": "^1.2.5",
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.19.2",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aigroup/aigroup-fmp-mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "financial-data",
    "fmp",
    "financial-modeling-prep",
    "stock-data",
    "market-data",
    "ai-assistant"
  ]
}